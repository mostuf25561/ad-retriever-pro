SCRAPER_BASE_URL=https://example.com
SCRAPER_GW_BASE_URL=https://gw.example.com
SCRAPER_USER_AGENT=Mozilla/5.0 ...
SCRAPER_ACCEPT_LANGUAGE=en-US,en;q=0.9
SCRAPER_MAX_RESULTS=26
SCRAPER_PHONE_CONCURRENCY=4

# Optional: authenticate to dramatically improve phone-reveal success.
# When both are set, the scraper POSTs to ${SCRAPER_GW_BASE_URL}/auth/login
# once and reuses the returned cookies/token for all reveal requests.
SCRAPER_LOGIN_EMAIL=
SCRAPER_LOGIN_PASSWORD=
